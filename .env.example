# Copy to .env (`cp .env.example .env`) before `pnpm start`. The app also runs without a .env by
# falling back to a documented DEV key — fine for the demo, NEVER for real PHI.
#
# PHI_ENCRYPTION_KEY: 32-byte AES-256 key, 64 hex chars. Encrypts the PHI columns at rest
# (members.name/dob, claims.provider/diagnosis_code). Generate a fresh one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHI_ENCRYPTION_KEY=ece4fafcc928af5f856d74559061f93812abe77848a77fcd099627b8175e5e77
